# The SymCrypt provider needs to be registered with libcrypto,
# either by config or with OSSL_PROVIDER_load. The provider can
# be disabled by commenting out or removing "activate = 1". The
# value assigned does not matter, and the provider will be
# activated as long as the "activate" key is present.

[symcrypt_prov_sect]
activate = 1
identity = symcryptprovider
keysinuse = keysinuse_sect

[keysinuse_sect]
enabled = 0
max_file_size = 5KB
logging_delay_seconds = 3600

# To make the SymCrypt provider the default random provider in
# OpenSSL 3.5+, add the following to the [random] section of
# your openssl.cnf (not in this provider config section):
#
# [random]
# random_provider = symcryptprovider
#
# This routes all RAND_bytes() and RAND_priv_bytes() calls
# directly through the SymCrypt provider, bypassing the
# default DRBG chain.
